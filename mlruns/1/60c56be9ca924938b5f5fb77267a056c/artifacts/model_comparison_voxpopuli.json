{
    "mlflow_params": {
        "tracking_uri": "sqlite:///mlruns_nested_try.db",
        "experiment_name": "Model Comparison (VoxPopuli)"
    },
    "data_params": {
        "dataset": "voxpopuli",
        "row_subsample": 1,
        "feature_subsample": 1,
        "standard_normalize": true,
        "seed": 42,
        "test_size": 0.1
    },
    "search_params": {
        "seed": 42,
        "num_samples": 12,
        "num_folds": 2,
        "test_size": 0.2,
        "refit": true
    },
    "evaluation_params": {
        "target_model_name": "FASTT_Alternating"
    },
    "models": {
        "Dummy_0": {
            "class_path": "s2t_fs.models.dummy_model.DummyModel",
            "init_args": { "target_index": 0 },
            "hyperparameters": {}
        },
        "Dummy_1": {
            "class_path": "s2t_fs.models.dummy_model.DummyModel",
            "init_args": { "target_index": 1 },
            "hyperparameters": {}
        },
        "Dummy_2": {
            "class_path": "s2t_fs.models.dummy_model.DummyModel",
            "init_args": { "target_index": 2 },
            "hyperparameters": {}
        },
        "Random_Ensemble": {
            "class_path": "s2t_fs.models.random_ensemble.RandomModel",
            "init_args": { "seed": 42 },
            "hyperparameters": {}
        },
        "Raw_SDT": {
            "class_path": "s2t_fs.models.sdtr_models.BoostedSDTR",
            "init_args": {
                "num_boosting_layers": 1,
                "epochs": 15,
                "batch_size": 1024
            },
            "hyperparameters": {
                "lr": [0.001, 0.01],
                "depth": [4, 6],
                "num_trees": [5, 10]
            }
        },
        "Raw_XGBoost": {
            "class_path": "s2t_fs.models.adastt_xgboost.AdaSTTXGBoost",
            "init_args": { "random_state": 42 },
            "hyperparameters": {
                "n_estimators": [5, 15, 30],
                "learning_rate": [0.05, 0.1],
                "max_depth": [3, 5, 8],
                "subsample": [0.8, 1.0]
            }
        },
        "SelectKBest_SDT": {
            "class_path": "sklearn.pipeline.Pipeline",
            "init_args": {
                "steps": [
                    [
                        "selector",
                        {
                            "class_path": "s2t_fs.models.multi_target_selector.MultiTargetSelectKBest",
                            "init_args": {}
                        }
                    ],
                    [
                        "model",
                        {
                            "class_path": "s2t_fs.models.sdtr_models.BoostedSDTR",
                            "init_args": {
                                "num_boosting_layers": 1,
                                "epochs": 15,
                                "batch_size": 1024
                            }
                        }
                    ]
                ]
            },
            "hyperparameters": {
                "selector__k": [5, 10, 20],
                "model__lr": [0.001, 0.01],
                "model__depth": [4, 6]
            }
        },
        "SelectKBest_XGBoost": {
            "class_path": "sklearn.pipeline.Pipeline",
            "init_args": {
                "steps": [
                    [
                        "selector",
                        {
                            "class_path": "s2t_fs.models.multi_target_selector.MultiTargetSelectKBest",
                            "init_args": {}
                        }
                    ],
                    [
                        "model",
                        {
                            "class_path": "s2t_fs.models.adastt_xgboost.AdaSTTXGBoost",
                            "init_args": { "random_state": 42 }
                        }
                    ]
                ]
            },
            "hyperparameters": {
                "selector__k": [5, 10, 20],
                "model__n_estimators": [5, 15],
                "model__max_depth": [3, 5]
            }
        },
        "FASTT_Boosted": {
            "class_path": "s2t_fs.models.fastt.fastt_boosted.FASTTBoosted",
            "init_args": {
                "transform_type": "diagonal",
                "random_state": 42,
                "epochs": 15
            },
            "hyperparameters": {
                "num_rounds": [2, 3],
                "num_trees": [5, 10],
                "lr": [0.001, 0.01],
                "depth": [4, 6]
            }
        },
        "FASTT_Alternating": {
            "class_path": "s2t_fs.models.fastt.fastt_alternating.FASTTAlternating",
            "init_args": {
                "transform_type": "diagonal",
                "transform_steps": 50,
                "random_state": 42,
                "base_selector": {
                    "class_path": "s2t_fs.models.adastt_xgboost.AdaSTTXGBoost",
                    "init_args": {
                        "n_estimators": 10,
                        "learning_rate": 0.1
                    }
                }
            },
            "hyperparameters": {
                "num_iterations": [3, 5],
                "transform_lr": [0.001, 0.01],
                "base_selector__max_depth": [3, 5]
            }
        }
    }
}
