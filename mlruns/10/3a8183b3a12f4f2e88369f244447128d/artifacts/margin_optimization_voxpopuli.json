{
    "mlflow_params": {
        "tracking_uri": "sqlite:///s2t-fs-experiments.db",
        "experiment_name": "Margin Optimization (VoxPopuli)"
    },
    "optimization_params": {
        "n_trials": 15,
        "seed": 42
    },
    "data_params": {
        "dataset": "voxpopuli",
        "row_subsample": 1,
        "feature_subsample": 1,
        "standard_normalize": true,
        "seed": 42,
        "test_size": [0.1, 0.15, 0.2]
    },
    "search_params": {
        "seed": 42,
        "num_samples": [10, 20],
        "num_folds": [1, 2],
        "test_size": 0.2,
        "refit": true
    },
    "evaluation_params": {
        "target_model_name": "FASTT_Alternating"
    },
    "models": {
        "Raw_XGBoost": {
            "class_path": "s2t_fs.models.adastt_xgboost.AdaSTTXGBoost",
            "init_args": {
                "random_state": 42
            },
            "hyperparameters": {
                "n_estimators": [5, 15],
                "learning_rate": [0.05, 0.1],
                "max_depth": [3, 5],
                "subsample": [0.8, 1.0]
            }
        },
        "FASTT_Alternating": {
            "class_path": "s2t_fs.models.fastt.fastt_alternating.FASTTAlternating",
            "init_args": {
                "transform_type": "diagonal",
                "transform_steps": 50,
                "random_state": 42,
                "base_selector": {
                    "class_path": "s2t_fs.models.adastt_xgboost.AdaSTTXGBoost",
                    "init_args": {
                        "n_estimators": 10,
                        "learning_rate": 0.1
                    }
                }
            },
            "hyperparameters": {
                "num_iterations": [3, 5],
                "transform_lr": [0.001, 0.01],
                "base_selector__max_depth": [3, 5]
            }
        }
    }
}
