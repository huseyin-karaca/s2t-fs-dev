name: s2t-fs

conda_env: environment.yml

entry_points:
  single_model_hpt:
    parameters:
      config:
        type: string
        default: configs/try_to_improve_our_models_voxpopuli.json
    command: "make run-single CONFIG={config}"

  model_comparison:
    parameters:
      config:
        type: string
        default: configs/model_comparison_voxpopuli.json
    command: "make run-comparison CONFIG={config}"

  margin_optimization:
    parameters:
      config:
        type: string
        default: configs/margin_optimization_voxpopuli.json
    command: "make run-margin CONFIG={config}"
