# ─────────────────────────────────────────────────────────────
#  s2t-fs environment variables
#  Copy this file to .env and fill in your values.
#  .env is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────

# ── vast.ai ──────────────────────────────────────────────────
# Get from: https://cloud.vast.ai/ → Account → API Key
VAST_API_KEY=your_vast_api_key_here

# ── GitHub / GHCR ────────────────────────────────────────────
# Your GitHub username (lowercase). Used to build the image name:
#   ghcr.io/<GITHUB_ACTOR>/s2t-fs:latest
GITHUB_ACTOR=your_github_username

# Full URL of this repo (used by onstart.sh to git-clone on the instance).
# Use HTTPS for public repos. For private repos, embed a PAT:
#   https://<PAT>@github.com/yourname/s2t-fs.git
GIT_REPO_URL=https://github.com/your_github_username/s2t-fs.git

# ── vast.ai instance defaults (all optional, override with CLI flags) ────────
# GPU model name as shown in: vastai search offers
GPU=RTX_3090

# Maximum price in $/hr
MAX_PRICE=0.30

# Disk size in GB allocated to the instance
DISK=30

# Minimum network speeds in Mbps (affects gdown data download and git clone time)
INET_DOWN=500
INET_UP=100

# Git branch to clone on the instance
GIT_BRANCH=main

# Full image path (auto-derived from GITHUB_ACTOR if left blank)
# VAST_IMAGE=ghcr.io/your_github_username/s2t-fs:latest

# ── MLflow (optional — only needed for remote tracking server) ───────────────
# Leave blank to use the default local SQLite tracking (sqlite:///s2t-fs-experiments.db)
# MLFLOW_TRACKING_URI=
# MLFLOW_TRACKING_USERNAME=
# MLFLOW_TRACKING_PASSWORD=
