{
  "mlflow_cfg": {
    "tracking_uri": "sqlite:///../mlruns_nested_try.db",
    "experiment_name": "Check"
  },
  "data_cfg": {
    "n_samples": 4000,
    "n_informative": 5,
    "n_noise": 25,
    "n_experts": 3,
    "test_size": 0.2,
    "seed": 0
  },
  "search_cfg": {
    "seed": 42,
    "num_samples": 2,
    "num_folds": 1,
    "test_size": 0.1,
    "refit": true
  },
  "model_cfg": {
    "model_name": "FASTTAlternating-Tuned",
    "class_path": "s2t_fs.models.fastt.fastt_alternating.FASTTAlternating",
    "init_args": {
      "transform_type": "diagonal",
      "transform_steps": 100,
      "random_state": 42,
      "base_selector": {
        "class_path": "s2t_fs.models.adastt_xgboost.AdaSTTXGBoost",
        "init_args": {
          "n_estimators": 50,
          "learning_rate": 0.1
        }
      }
    },
    "hyperparameters": {
      "num_iterations": [
        5,
        10
      ],
      "transform_lr": [
        0.001,
        0.01
      ],
      "base_selector__max_depth": [
        3,
        4
      ]
    }
  }
}