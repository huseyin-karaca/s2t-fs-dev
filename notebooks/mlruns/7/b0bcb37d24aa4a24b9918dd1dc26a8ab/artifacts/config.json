{
  "mlflow_cfg": {
    "tracking_uri": "sqlite:///s2t-fs-experiments.db",
    "experiment_name": "Check",
    "run_name": "FASTT-Boosted-MLP-Linear"
  },
  "data_cfg": {
    "n_samples": 1500,
    "n_informative": 4,
    "n_noise": 16,
    "n_experts": 2,
    "test_size": 0.2,
    "seed": 42
  },
  "search_cfg": {
    "seed": 42,
    "num_samples": 2,
    "num_folds": 1,
    "test_size": 0.1,
    "refit": true
  },
  "model_cfg": {
    "model_name": "FASTTBoosted",
    "class_path": "s2t_fs.models.fastt.fastt_boosted.FASTTBoosted",
    "init_args": {
      "transform_type": "linear",
      "num_rounds": 2,
      "epochs": 5,
      "base_estimator": {
        "class_path_": "s2t_fs.models.adastt_mlp._MLPDifferentiable",
        "init_args_": {
          "dropout_rate": 0.1
        }
      }
    },
    "hyperparameters": {
      "lr": [
        0.01,
        0.005
      ]
    }
  }
}