{
  "mlflow_cfg": {
    "tracking_uri": "sqlite:///s2t-fs-experiments.db",
    "experiment_name": "Check",
    "run_name": "FASTT-Alternating-LightGBM-Nonlinear"
  },
  "data_cfg": {
    "n_samples": 1500,
    "n_informative": 4,
    "n_noise": 16,
    "n_experts": 2,
    "test_size": 0.2,
    "seed": 42
  },
  "search_cfg": {
    "seed": 42,
    "num_samples": 2,
    "num_folds": 1,
    "test_size": 0.1,
    "refit": true
  },
  "model_cfg": {
    "model_name": "FASTTAlternating",
    "class_path": "s2t_fs.models.fastt.fastt_alternating.FASTTAlternating",
    "init_args": {
      "transform_type": "nonlinear",
      "transform_steps": 50,
      "base_selector": {
        "class_path": "s2t_fs.models.adastt_lightgbm.AdaSTTLightGBM",
        "init_args": {
          "n_estimators": 50,
          "learning_rate": 0.1
        }
      },
      "transform_kwargs": {
        "bottleneck_dim": 4
      }
    },
    "hyperparameters": {
      "num_iterations": [
        2,
        3
      ],
      "transform_lr": [
        0.01
      ]
    }
  }
}