{
    "mlflow_params": {
        "tracking_uri": "sqlite:///s2t-fs-experiments.db",
        "experiment_name": "Model Comparison (Ami)"
    },
    "data_params": {
        "dataset": "ami",
        "row_subsample": 0.75,
        "feature_subsample": 1,
        "standard_normalize": true,
        "seed": 42,
        "test_size": 0.1
    },
    "search_params": {
        "seed": 0,
        "num_samples": 10,
        "num_folds": 1,
        "test_size": 0.1,
        "refit": true,
        "trial_parallel": false,
        "model_parallel": false
    },
    "evaluation_params": {
        "target_model_names": [
            "FASTT_Alternating",
            "FASTT_Boosted"
        ]
    },
    "models": {
        "FASTT_Alternating": {
            "class_path": "s2t_fs.models.fastt.fastt_alternating.FASTTAlternating",
            "init_args": {
                "transform_type": "nonlinear",
                "transform_steps": 200,
                "transform_weight_decay": 0.01,
                "transform_lambda1": 0.01,
                "transform_lambda2": 0.01,
                "random_state": 42,
                "base_selector": {
                    "class_path": "s2t_fs.models.adastt_xgboost.AdaSTTXGBoost",
                    "init_args": {
                        "n_estimators": 20,
                        "learning_rate": 0.05,
                        "max_depth": 10,
                        "subsample": 1.0,
                        "colsample_bytree": 0.6,
                        "min_child_weight": 4,
                        "reg_lambda": 5.0
                    }
                }
            },
            "hyperparameters": {
                "num_iterations": [
                    5,
                    8,
                    10
                ],
                "transform_lr": [
                    0.001,
                    0.005,
                    0.01
                ],
                "transform_steps": [
                    100,
                    150,
                    200
                ],
                "base_selector__max_depth": [
                    5,
                    7,
                    10
                ]
            }
        }
    },
    "FASTT_Boosted": {
        "class_path": "s2t_fs.models.fastt.fastt_boosted.FASTTBoosted",
        "init_args": {
            "transform_type": "low_rank",
            "random_state": 42,
            "lr": 0.0005,
            "weight_decay": 1e-05,
            "epochs": 60,
            "patience": 20,
            "batch_size": 512
        },
        "hyperparameters": {
            "num_rounds": [
                3,
                5,
                8
            ],
            "num_trees": [
                10,
                15,
                20
            ],
            "depth": [
                3,
                4,
                6
            ],
            "lr": [
                0.0001,
                0.0005,
                0.001
            ]
        }
    }
}