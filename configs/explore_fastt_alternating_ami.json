{
    "mlflow_params": {
        "tracking_uri": "sqlite:///s2t-fs-experiments.db",
        "experiment_name": "Try to Improve Our Models (Ami)"
    },
    "data_params": {
        "dataset": "ami",
        "row_subsample": 1,
        "feature_subsample": 1,
        "standard_normalize": true,
        "seed": 42,
        "test_size": 0.1
    },
    "search_params": {
        "seed": 42,
        "num_samples": 50,
        "num_folds": 1,
        "test_size": 0.1,
        "refit": true,
        "trial_parallel": false,
        "model_parallel": false     
    },
    "models": {
        "FASTT_Alternating": {
            "class_path": "s2t_fs.models.fastt.fastt_alternating.FASTTAlternating",
            "init_args": {
                "transform_type": "diagonal",
                "transform_steps": 50,
                "random_state": 42,
                "base_selector": {
                    "class_path": "s2t_fs.models.adastt_xgboost.AdaSTTXGBoost",
                    "init_args": {
                        "n_estimators": 10,
                        "learning_rate": 0.1,
                        "random_state": 42
                    }
                }
            },
            "hyperparameters": {
                "transform_type": [
                    "diagonal",
                    "linear",
                    "low_rank",
                    "nonlinear"
                ],
                "transform_weight_decay": [
                    0.00001,
                    0.0001,
                    0.001,
                    0.01
                ],
                "transform_lambda1": [
                    0.001,
                    0.01,
                    0.1,
                    1.0
                ],
                "transform_lambda2": [
                    0.001,
                    0.01,
                    0.1,
                    1.0
                ],
                "num_iterations": [
                    2,
                    3,
                    5,
                    8,
                    10
                ],
                "transform_lr": [
                    0.0001,
                    0.001,
                    0.005,
                    0.01,
                    0.05
                ],
                "transform_steps": [
                    30,
                    50,
                    100,
                    200
                ],
                "base_selector__n_estimators": [
                    5,
                    10,
                    20,
                    50
                ],
                "base_selector__max_depth": [
                    2,
                    3,
                    5,
                    7,
                    10
                ],
                "base_selector__learning_rate": [
                    0.01,
                    0.05,
                    0.1,
                    0.2
                ],
                "base_selector__subsample": [
                    0.6,
                    0.8,
                    1.0
                ],
                "base_selector__colsample_bytree": [
                    0.4,
                    0.6,
                    0.8,
                    1.0
                ],
                "base_selector__min_child_weight": [
                    1,
                    4,
                    8
                ],
                "base_selector__reg_lambda": [
                    0.1,
                    1.0,
                    5.0,
                    10.0
                ]
            }
        }
    }
