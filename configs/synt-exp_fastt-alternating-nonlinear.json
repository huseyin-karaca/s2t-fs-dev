{
    "mlflow_params": {
        "tracking_uri": "sqlite:///s2t-fs-experiments.db",
        "experiment_name": "Check",
        "run_name": "FASTT-Alternating-Nonlinear-XGBoost"
    },
    "data_params": {
        "source": "synthetic",
        "n_samples": 3000,
        "n_informative": 4,
        "n_noise": 10,
        "n_experts": 2,
        "test_size": 0.2,
        "seed": 100
    },
    "search_params": {
        "seed": 42,
        "num_samples": 2,
        "num_folds": 1,
        "test_size": 0.1,
        "refit": true
    },
    "models": {
        "FASTTAlternating": {
            "class_path": "s2t_fs.models.fastt.fastt_alternating.FASTTAlternating",
            "init_args": {
                "transform_type": "nonlinear",
                "transform_steps": 100,
                "random_state": 42,
                "transform_kwargs": {"bottleneck_dim": 5},
                "base_selector": {
                    "class_path": "s2t_fs.models.adastt_xgboost.AdaSTTXGBoost",
                    "init_args": {
                        "n_estimators": 50,
                        "learning_rate": 0.1
                    }
                }
            },
            "hyperparameters": {
                "num_iterations": [3, 5],
                "transform_lr": [0.001, 0.01],
                "base_selector__max_depth": [3, 4]
            }
        }
    },
    "callbacks": [
        {
            "class_path": "s2t_fs.callbacks.plot_feature_importances.PlotFeatureImportances",
            "init_args": {"n_informative": 4}
        }
    ]
}
